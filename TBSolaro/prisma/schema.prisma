generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  status        String   @default("draft")
  category      String   @default("combo")
  sortOrder     Int      @default(0)
  downloadUrl   String   @default("")
  featuredImage String   @default("")
  gallery       String   @default("[]")
  tags          String   @default("[]")
  relatedSlugs  String   @default("[]")
  seoOgImage    String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  titleVi    String
  titleEn    String   @default("")
  titleEs    String   @default("")
  subtitleVi String   @default("")
  subtitleEn String   @default("")
  subtitleEs String   @default("")
  excerptVi  String   @default("")
  excerptEn  String   @default("")
  excerptEs  String   @default("")
  featuresVi String   @default("[]")
  featuresEn String   @default("[]")
  featuresEs String   @default("[]")
  specsVi    String   @default("{}")
  specsEn    String   @default("{}")
  specsEs    String   @default("{}")
  tiersVi    String   @default("[]")
  tiersEn    String   @default("[]")
  tiersEs    String   @default("[]")
  seoTitleVi String   @default("")
  seoTitleEn String   @default("")
  seoTitleEs String   @default("")
  seoDescVi  String   @default("")
  seoDescEn  String   @default("")
  seoDescEs  String   @default("")
}

model Project {
  id               String   @id @default(cuid())
  slug             String   @unique
  status           String   @default("draft")
  category         String   @default("enterprise")
  sortOrder        Int      @default(0)
  location         String   @default("")
  power            String   @default("")
  installationDate String   @default("")
  year             String   @default("")
  videoUrl         String   @default("")
  featuredImage    String   @default("")
  gallery          String   @default("[]")
  relatedSlugs     String   @default("[]")
  seoOgImage       String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  titleVi    String
  titleEn    String   @default("")
  titleEs    String   @default("")
  excerptVi  String   @default("")
  excerptEn  String   @default("")
  excerptEs  String   @default("")
  contentVi  String   @default("")
  contentEn  String   @default("")
  contentEs  String   @default("")
  seoTitleVi String   @default("")
  seoTitleEn String   @default("")
  seoTitleEs String   @default("")
  seoDescVi  String   @default("")
  seoDescEn  String   @default("")
  seoDescEs  String   @default("")
}

model SiteSetting {
  id        String   @id @default("global")
  updatedAt DateTime @updatedAt

  // Branding
  logoUrl   String @default("")

  // Homepage Hero Slider (JSON array of HeroSlide objects)
  heroSlides     String @default("[]")
  // Legacy single-slide fields kept for backwards compat
  heroImage      String @default("")
  heroTitleVi    String @default("")
  heroTitleEn    String @default("")
  heroTitleEs    String @default("")
  heroSubtitleVi String @default("")
  heroSubtitleEn String @default("")
  heroSubtitleEs String @default("")

  // Page hero backgrounds
  productsHeroImage  String @default("")
  projectsHeroImage  String @default("")
  aboutHeroImage     String @default("")
  contactHeroImage   String @default("")
  communityHeroImage String @default("")
  faqHeroImage       String @default("")
  showroomHeroImage  String @default("")

  // Sustainability Banner
  sustainabilityBgImage String @default("")

  // Hero badge (shown in the hero slider banner)
  heroBadgeVi String @default("")
  heroBadgeEn String @default("")
  heroBadgeEs String @default("")

  // About page content
  aboutTimeline String @default("[]")  // JSON: [{year,titleVi,titleEn,titleEs,descVi,descEn,descEs}]
  aboutWhyUs    String @default("[]")  // JSON: [{label,titleVi,titleEn,titleEs,descVi,descEn,descEs}]
  aboutProcess  String @default("[]")  // JSON: [{num,titleVi,titleEn,titleEs,descVi,descEn,descEs}]
  aboutPartners String @default("")    // comma-separated partner names

  // Homepage section backgrounds
  csrImage              String @default("")
  productsSectionBg     String @default("")
  statsSectionBg        String @default("")
  testimonialsSectionBg String @default("")
  newsSectionBg         String @default("")
  contactSectionBg      String @default("")

  // Footer contact
  footerPhone    String @default("")
  footerEmail    String @default("")
  footerAddress  String @default("")
  footerFacebook String @default("")
  footerYoutube  String @default("")

  // Section titles (JSON: {home:{productsTitle:{vi,en,es},...}, products:{...}, projects:{...}, about:{...}})
  sectionTitles String @default("{}")
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  keyPrefix   String
  permissions String    @default("read")
  status      String    @default("active")
  lastUsed    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model WikiPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   @default("")
  sortOrder Int      @default(0)
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("editor")
  status       String    @default("active")
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Showroom {
  id           String   @id @default(cuid())
  status       String   @default("draft")
  sortOrder    Int      @default(0)
  name         String
  address      String   @default("")
  phone        String   @default("")
  email        String   @default("")
  openingHours String   @default("")
  mapEmbed     String   @default("")
  lat          Float?
  lng          Float?
  gallery      String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model FAQ {
  id         String   @id @default(cuid())
  status     String   @default("draft")
  category   String   @default("")
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  questionVi String
  questionEn String   @default("")
  questionEs String   @default("")
  answerVi   String
  answerEn   String   @default("")
  answerEs   String   @default("")
}

model DownloadDocument {
  id            String   @id @default(cuid())
  status        String   @default("draft")
  sortOrder     Int      @default(0)
  title         String
  description   String   @default("")
  fileUrl       String   @default("")
  fileType      String   @default("PDF")
  category      String   @default("")
  version       String   @default("")
  featuredImage String   @default("")
  icon          String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BlogPost {
  id            String    @id @default(cuid())
  slug          String    @unique
  slugEn        String    @default("")
  slugEs        String    @default("")
  status        String    @default("draft")
  publishedAt   DateTime?
  author        String    @default("Admin")
  featuredImage String    @default("")
  gallery       String    @default("[]")
  tags          String    @default("[]")
  relatedSlugs  String    @default("[]")
  seoOgImage    String    @default("")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  titleVi    String
  titleEn    String   @default("")
  titleEs    String   @default("")
  excerptVi  String   @default("")
  excerptEn  String   @default("")
  excerptEs  String   @default("")
  contentVi  String   @default("")
  contentEn  String   @default("")
  contentEs  String   @default("")
  seoTitleVi String   @default("")
  seoTitleEn String   @default("")
  seoTitleEs String   @default("")
  seoDescVi  String   @default("")
  seoDescEn  String   @default("")
  seoDescEs  String   @default("")
}
