# TBSolaro — Required Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing real credentials.
#
# In Vercel: set each variable separately for Production vs Preview
# environments (Project Settings → Environment Variables).
# ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon)
# Production: use the "main" Neon branch connection string
# Staging:    use the "staging" Neon branch connection string
# Get from: Neon Dashboard → Connection Details → Connection string
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/tbsolaro?sslmode=require"

# Vercel Blob storage read/write token
# Production: use the production Blob store token
# Staging:    can share the same store or use a separate staging store
# Get from: Vercel Dashboard → Storage → Blob → your store → .env.local tab
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Admin login credentials
# Change these from the defaults before any public or team deployment
ADMIN_EMAIL="admin@tbsolaro.com"
ADMIN_PASSWORD="change-me-to-something-strong"
